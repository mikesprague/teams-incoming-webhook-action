{
  "name": "teams-incoming-webhook-action",
  "version": "2.0.3",
  "description": "GitHub Action to send an MS Teams notification via Incoming Webhook",
  "main": "./src/index.ts",
  "private": "true",
  "type": "module",
  "scripts": {
    "build": "npm run prepare",
    "changelog": "npx conventional-changelog -p conventionalcommits -n changelog.config.mjs -i CHANGELOG.md -s && git add CHANGELOG.md",
    "declarations": "rm -rf ./types && tsc --emitDeclarationOnly --declaration true --declarationDir './types'",
    "lint": "npx biome check ./src",
    "lint:fix": "npx biome check --write ./src",
    "version": "npm run changelog",
    "postbuild": "npm run typedoc-html",
    "prepare": "rm -rf dist && ncc build --source-map --license licenses.txt",
    "test": "vitest run --coverage && npm run lint && npm run typecheck",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:junit": "vitest run --reporter=junit --outputFile=test-report.junit.xml",
    "typecheck": "tsc --noEmit",
    "typedoc": "typedoc --out ./docs --entryPointStrategy expand ./src --plugin typedoc-plugin-markdown --readme none",
    "typedoc-html": "typedoc --out ./docs/publish --entryPointStrategy expand ./src --readme ./README.md"
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.12.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikesprague/teams-incoming-webhook-action.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "TypeScript"
  ],
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/teams-incoming-webhook-action/issues"
  },
  "homepage": "https://github.com/mikesprague/teams-incoming-webhook-action#readme",
  "dependencies": {
    "@actions/core": "3.0.0",
    "@octokit/rest": "22.0.1",
    "dayjs": "1.11.20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@octokit/types": "16.0.0",
    "@types/node": "25.6.0",
    "@vercel/ncc": "0.38.4",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "commitizen": "4.3.1",
    "conventional-changelog": "7.2.0",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "cz-git": "1.12.0",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "overrides": {
    "@conventional-changelog/git-client": "^2.7.0",
    "flatted": "^3.4.2",
    "lodash": "^4.18.1",
    "minimatch": "^10.2.5",
    "tmp": "^0.2.5",
    "undici": "^8.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "25.9.0",
    "npm": "11.12.1"
  }
}
